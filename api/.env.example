# Variáveis de ambiente do backend FastAPI (NÃO commitar o .env real).
# No Railway/Render, configure isto no painel de Environment Variables.

# Usuários: JSON {usuario: hash_sha256_da_senha}. Use o MESMO hash do Streamlit
# (gere com: python scripts/gerar_hash_senha.py).
TABLM_USERS={"leonardo":"COLOQUE_O_HASH_AQUI"}

# Segredo para assinar o JWT (gere algo longo e aleatório).
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio
JWT_EXPIRE_HOURS=12

# Google Gemini (mesma chave do Streamlit).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Supabase (service_role).
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_KEY=SERVICE_ROLE_KEY

# Origens permitidas (CORS) — em produção, o domínio do Vercel.
CORS_ORIGINS=http://localhost:3000

# Notificações por email (Vercel Cron diário 9h BRT chama o backend).
# Se RESEND_API_KEY ou NOTIFICACOES_EMAIL_DESTINO ficarem vazios, o
# endpoint /notificacoes/disparar-promocoes-vencendo devolve enviado=false
# com motivo no body (não erra). CRON_SECRET vazio recusa qualquer chamada.
RESEND_API_KEY=
CRON_SECRET=
NOTIFICACOES_EMAIL_DESTINO=
# Quando vazio, usa "TabLM <onboarding@resend.dev>" (sandbox do Resend).
NOTIFICACOES_EMAIL_REMETENTE=

# CV CRM (Ribeira) — leitura de tabelas de preço via Bearer Token.
# Token gerado em Configurações → Integrações → APIs (validade 90d na
# Ribeira). Sem CVCRM_TOKEN preenchido, os endpoints /cvcrm/* retornam 502.
CVCRM_BASE_URL=https://integracao.cvcrm.com.br/api
CVCRM_TOKEN=
