# Copie este arquivo para .streamlit/secrets.toml e preencha com valores reais.
# NUNCA comite o secrets.toml real no git (já está no .gitignore).
#
# Gere o hash de cada senha com:
#   python scripts/gerar_hash_senha.py

# Para adicionar mais usuários, basta acrescentar novas linhas em [auth.usuarios].
[auth]
[auth.usuarios]
leonardo = "HASH_AQUI"

[empresa]
nome = "Ribeira Empreendimentos"
ambiente = "producao"

# IA para extração de books/flyers (aba Extração). Opcional — sem isto,
# o app permite preenchimento manual. O app escolhe o provedor pela chave
# presente: Gemini tem prioridade (grátis); Claude é reforço opcional.

# Gemini (grátis) — pegue a chave em https://aistudio.google.com (Get API key).
[gemini]
api_key = "AIza..."
# model = "gemini-2.5-flash"   # opcional: troque se o padrão der erro

# Claude (pago, ~centavos/doc) — pegue a chave em https://console.anthropic.com.
# [anthropic]
# api_key = "sk-ant-..."

# Histórico persistente da base de mercado (opcional). Veja src/mercado_store.py.
# [gsheets]
# spreadsheet_id = "ID_DA_PLANILHA"
# [gsheets.service_account]
# type = "service_account"
# ...
