# Copie este arquivo para .streamlit/secrets.toml e preencha com valores reais.
# NUNCA comite o secrets.toml real no git (já está no .gitignore).
#
# Gere o hash de cada senha com:
#   python scripts/gerar_hash_senha.py

# Para adicionar mais usuários, basta acrescentar novas linhas em [auth.usuarios].
[auth]
[auth.usuarios]
leonardo = "HASH_AQUI"

[empresa]
nome = "Ribeira Empreendimentos"
ambiente = "producao"
